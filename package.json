{
  "name": "prayer-times-tv",
  "version": "1.0.0",
  "private": true,
  "description": "High-visibility prayer times dashboard for Smart TVs and large displays",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 30",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci-check": "npm ci && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "adhan": "^4.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "suncalc": "^1.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.11.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.3",
    "vite": "^8.0.13",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
