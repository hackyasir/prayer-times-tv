# Dependencies
node_modules/
.pnpm-store/
jspm_packages/

# Build output
dist/
dist-ssr/
build/
.vite/

# Local env files (never commit secrets)
.env
.env.local
.env.*.local
*.pem

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Test coverage reports — generated by `npm run test:coverage`
coverage/
*.lcov
.nyc_output/

# Vitest cache — recreated automatically on each test run
.vitest-cache/

# Misc — temp files, OS metadata, lock files from other package managers
*.log
*.tmp
*.tgz
.npm/
.yarn/
.cache/

# Optional: keep package-lock.json but NOT yarn/pnpm lockfiles if mixing
# tools is undesirable. Uncomment if relevant.
# yarn.lock
# pnpm-lock.yaml
