.npm/
.yarn/
.cache/

# Local dev sync — see sync.bat (apply Claude zips) and upload.bat
# (package your code for Claude review) for the workflow. precheck.bat
# is the pre-push quality gate. All three are personal-machine helpers,
# not project artifacts. The *.bat catch-all also covers any future helper.
*.bat
sync.bat
upload.bat
precheck.bat
_unzip_temp/

# Defensive — if someone accidentally extracts an upload/sync zip
# INTO the project root via Right-click → Extract All, these folders
# would otherwise duplicate the project contents and break the next
# upload/sync cycle.
prayer-times-tv-upload/
prayer-times-tv/
prayer-times-tv-upload.zip
prayer-times-tv.zip

# Optional: keep package-lock.json but NOT yarn/pnpm lockfiles if mixing
# tools is undesirable. Uncomment if relevant.
# yarn.lock
# pnpm-lock.yaml

# Local-only Copilot instruction overrides (personal preferences)
.github/instructions/telegram-style.instructions.md

# Local planning / scratch docs (not tracked per maintainer preference)
BACKLOG.md
