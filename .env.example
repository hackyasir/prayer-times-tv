# Prayer Times TV Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git (it's in .gitignore).

# ── Settings PIN (optional) ──────────────────────────────────────────────────
# If set, a PIN prompt will appear before the settings panel can be opened.
# Useful for mosque/kiosk deployments where you don't want visitors changing times.
# Leave blank or remove to allow open access (default).
VITE_SETTINGS_PIN=

# Examples:
# VITE_SETTINGS_PIN=1234
# VITE_SETTINGS_PIN=786

# ── Test buttons (Jumu'ah preview toggle in footer) ──────────────────────────
# Set to 'false' to hide test buttons in production / kiosk deployments.
# Defaults to 'true' (visible) if not set.
VITE_SHOW_TEST_BUTTONS=true

# Production example (hide everything):
# VITE_SETTINGS_PIN=1234
# VITE_SHOW_TEST_BUTTONS=false
